# ls
alias ls='ls --color=auto'
alias ll='ls -l'
alias la='ls -A'
alias l='ls -CF'

# just think twice man ;)
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -iv'

# moving around
alias ..='cd ..'
alias ...='cd ../..'

# grep with colors
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

# system administration
alias ccache='sudo paccache -r'
alias kcache='sudo paccache -ruk0'
alias update='sudo pacman -Syu'

# git
alias ggaa='git add .'
alias ggca='git commit -a'
alias gglg='git log --graph'
alias ggll='git pull origin main'
alias ggsh='git push origin main'
alias ggst='git status'

# irssi
alias irssi="irssi --config=${XDG_CONFIG_HOME}/irssi/config --home=${XDG_DATA_HOME}/irssi"

# conf files
alias alconf="vim ${XDG_CONFIG_HOME}/zsh/zsh_aliases"
alias evconf="vim ${HOME}/.zshenv"
alias i3conf="vim ${XDG_CONFIG_HOME}/i3/config"
alias taconf="vim ${XDG_DATA_HOME}/pta/ledger.dat"
alias toconf="vim ${XDG_DATA_HOME}/pto/ledger.dat"
alias txconf="vim ${XDG_CONFIG_HOME}/tmux/tmux.conf"
alias xrconf="vim ${HOME}/.Xresources && xrdb ${HOME}/.Xresources"

# open files with these suffices with vim by default
alias -s c='vim'
alias -s h='vim'
alias -s conf='vim'
alias -s html='firefox'
alias -s md='vim'
alias -s pdf='zathura'
alias -s py='vim'
alias -s sh='vim'
alias -s tex='vim'
alias -s txt='vim'

# python virtual environments
alias ae='. venv/bin/activate'
alias de='deactivate'
