# grep with colors
alias egrep='egrep --color=auto'
alias fgrep='fgrep --color=auto'

# ls with colors
alias ls='ls --color=auto'
alias ll='ls -lh'
alias la='ls -la'

# think twice ;)
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -iv'

alias ..='cd ..'
alias ...='cd ../..'

# system administration
alias update='sudo pacman -Syu'

# git
alias ggaa='git add .'
alias ggca='git commit -a'
alias gglg='git log --graph'
alias ggll='git pull origin main'
alias ggsh='git push origin main'
alias ggst='git status'

# irssi
alias irssi="irssi --config=${XDG_CONFIG_HOME}/irssi/config --home=${XDG_DATA_HOME}/irssi"

# config files
alias alconfig="nvim ${XDG_CONFIG_HOME}/zsh/zsh_aliases"
alias evconfig="nvim ${HOME}/.zshenv"
alias i3config="nvim ${XDG_CONFIG_HOME}/i3/config"
alias taconfig="nvim ${XDG_DATA_HOME}/pta/ledger.dat"
alias tmconfig="nvim ${XDG_CONFIG_HOME}/tmux/tmux.conf"
alias toconfig="nvim ${XDG_DATA_HOME}/pto/ledger.dat"
alias xrconfig="nvim ${HOME}/.Xresources"

# open files with these suffices with nvim by default
alias -s c='nvim'
alias -s conf='nvim'
alias -s html='firefox'
alias -s md='nvim'
alias -s pdf='zathura'
alias -s py='nvim'
alias -s sh='nvim'
alias -s tex='nvim'
alias -s txt='nvim'

# python virtual environments
alias ae='. venv/bin/activate'
alias de='deactivate'
