# htop
alias htop='htop -C'

# ls
if [ "$(uname -s)" = 'Linux' ]
then
  alias la='ls --color=auto -A'
  alias ll='ls --color=auto -l'
  alias ls='ls --color=auto'
elif [ "$(uname -s)" = 'Darwin' ]
then
  alias la='ls -G -A'
  alias ll='ls -G -l'
  alias ls='ls -G'
fi

