# file management
alias cp='cp -iv'
alias mv='mv -iv'
alias rm='rm -iv'

# git
alias gaa='git add .'
alias gca='git commit -a'
alias gff='git diff'
alias glg='git log --graph --oneline --decorate'
alias gll='git pull origin main:main'
alias gsh='git push origin main:main'
alias gst='git status'

# htop
alias htop='htop -C'

# irssi
alias irssi="irssi --config=${HOME}/.config/irssi/config --home=${HOME}/.local/share/irssi"

# ls
alias la='ls --color=auto -A'
alias ll='ls --color=auto -l'
alias ls='ls --color=auto'

# swaylock
alias lock='swaylock'

# monitors
# alias emttl='xrandr --output DP-1 --auto --left-of eDP-1'
# alias emttr='xrandr --output DP-1 --auto --right-of eDP-1'

# newsboat
alias news='newsboat'

# python virtual environments
alias ae='. venv/bin/activate'
alias de='deactivate'

# sqlite
alias sqlite3="sqlite3 --init ${HOME}/.config/sqlite3/sqliterc"

# change directory
alias ..='cd ..'
alias ...='cd ../..'

alias gd="change_directory"
alias gf="change_file"

alias purgeable="dpkg -l | sed -n '/^ii/!p' | tail +6"
