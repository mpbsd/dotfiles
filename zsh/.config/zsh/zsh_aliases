alias news='newsboat'

# python virtual environments
alias ae='. venv/bin/activate'
alias de='deactivate'

# sqlite
alias sqlite3="sqlite3 --init ${HOME}/.config/sqlite3/sqliterc"

# change directory
alias ..='cd ..'
alias ...='cd ../..'

alias purgeable="dpkg -l | sed -n '/^ii/!p' | tail +6"
