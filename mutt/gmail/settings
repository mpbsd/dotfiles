###############
# IMAP
#
set folder       = imaps://imap.gmail.com/
set header_cache = "${XDG_CACHE_HOME}/mutt/gmail/cache/headers"
set imap_pass    = `gpg -q -d "${XDG_CONFIG_HOME}/mutt/gmail/password.gpg"`
set imap_user    = johnsmith@gmail.com
set mail_check   = 300
set postponed    = +[Gmail]/Drafts
set spoolfile    = +INBOX

###############
# SMTP
#
set from                = johnsmith@gmail.com
set realname            = 'John Smith'
set smtp_authenticators = 'login'
set smtp_url            = smtp://$imap_user:$imap_pass@smtp.gmail.com:587/
set ssl_force_tls       = yes
set trash               = +Trash
unset record
