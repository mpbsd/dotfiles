let mapleader      = ' '
let maplocalleader = ','

let s:rc_files_dir = '~/.vim/rc/'

let s:rc_filenames = [
      \'options',
      \'globals',
      \'autocmd',
      \'keymaps',
      \'caching',
      \'guiopts',
      \'plugins',
      \]

for rc_file in s:rc_filenames
  let s:f = s:rc_files_dir . rc_file . '.vim'
  let s:c = 'source ' . s:f
  exe s:c
endfor
