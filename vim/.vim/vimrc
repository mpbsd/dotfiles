let mapleader      = ','
let maplocalleader = ' '

let s:rc_files_dir = glob('~/.vim/rc/')

let s:rc_filenames = [
      \'autocmd',
      \'caching',
      \'globals',
      \'guiopts',
      \'keymaps',
      \'options',
      \'plugins',
      \'speller',
      \]

for rc_file in s:rc_filenames
  let s:f = s:rc_files_dir . rc_file . '.vim'
  let s:c = 'source ' . s:f
  exe s:c
endfor
