# i3status configuration file.
# see "man i3status" for documentation.

# It is important that this file is edited as UTF-8.
# The following line should contain a sharp s:
# ß
# If the above line is not correctly displayed, fix your editor first!

general {
  colors    = true
  interval  = 5
}

# order += "ipv6"
order += "wireless _first_"
order += "battery all"
order += "volume master"
order += "disk /"
order += "disk /home"
order += "cpu_temperature 0"
order += "cpu_usage"
order += "memory"
order += "tztime local"

wireless _first_ {
  format_up   = "[W] (%quality at %essid) %ip"
  format_down = "[W] down"
}

battery all {
  format = "[B] %status %percentage %remaining"
}

volume master {
  format = "[V] %volume"
  format_muted = "[V] muted"
  device = "default"
}

disk "/" {
  format = "[R] %percentage_used"
}

disk "/home" {
  format = "[H] %percentage_used"
}

cpu_temperature "0" {
  format = "[T] %degrees °C"
}

cpu_usage {
  format = "[P] %usage"
}

memory {
  format             = "[M] %percentage_used"
  threshold_degraded = "1G"
  format_degraded    = "[A] < %available"
}

tztime local {
  format = "[D] %a, %b %d %Y %R"
}
