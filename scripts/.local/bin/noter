#!/bin/bash


ROOT_DIR="${HOME}/.local/share/references"
BIBFILE="${ROOT_DIR}/zotero.bib"
OS="$(uname -s)"


[ -d "$ROOT_DIR" ] || exit 3
[ -f "$BIBFILE" ]  || exit 4


KEY="$(sed -n '/^@/p' "$BIBFILE" | sed 's/\(^@[^{]\+{\|,$\)//g' | dmenu -i)"


if [ "$OS" = 'Linux' ]
then
  echo -n "$KEY" | xclip -selection clipboard
fi


exit 0
