#!/bin/bash


ROOT_DIR="${HOME}/.local/share/references"
BIBFILE="${ROOT_DIR}/zotero.bib"


[ -d "$ROOT_DIR" ] || exit 2
[ -f "$BIBFILE" ] || exit 3


OS="$(uname -s)"


KEY="$(sed -n '/^@/p' "$BIBFILE" | sed 's/\(^@[^{]\+{\|,$\)//g' | fzf)"


if [ "$OS" = 'Linux' ]
then
  echo -n "$KEY" | xclip -selection clipboard
fi


exit 0
