#!/bin/bash


ROOT_DIR="${HOME}/templates/latex/github/cnotes"
ROOT_JSON_FILE="${ROOT_DIR}/chp/index.json"


[ -d "$ROOT_DIR" ]       || exit 3
[ -f "$ROOT_JSON_FILE" ] || exit 4


DISCIPLINE() {
  CHOICE=$(jq '.[] | "\(.id)> \(.disciplina)"' < "$ROOT_JSON_FILE" | fzf)
  echo "$CHOICE"
}


ID=$(DISCIPLINE | sed 's/^"\([0-9]\{2\}\)>.*/\1/g')
LOC_DIR="${ROOT_DIR}/chp/${ID}"
LOC_JSON_FILE="${LOC_DIR}/index.json"
LOC_TEX_FILE="${LOC_DIR}/index.tex"


[ -d "$LOC_DIR" ]       || exit 5
[ -f "$LOC_JSON_FILE" ] || exit 6
[ -f "$LOC_TEX_FILE" ]  || exit 7


TGT_DIR="${LOC_DIR}/sec"


[ -d "$TGT_DIR" ] || exit 8


DATE="$(date +'%Y%m%d')"
TGT_JSON_FILE="${TGT_DIR}/${DATE}.json"
TGT_TEX_FILE="${TGT_DIR}/${DATE}.tex"


if [ -f "$TGT_JSON_FILE" ] && [ -f "$TGT_TEX_FILE" ]
then
  vim -O "$TGT_TEX_FILE" "$TGT_JSON_FILE"
else
  touch "${TGT_JSON_FILE}"
  touch "${TGT_TEX_FILE}"
  printf '\n\input{chp/%s/sec/%s.tex}' "${ID}" "${DATE}" >> "$LOC_TEX_FILE"
  vim -O "$TGT_JSON_FILE" "$TGT_TEX_FILE"
fi


exit 0
