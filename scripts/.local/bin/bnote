#!/bin/bash


ROOTDIR="${HOME}/.local/share/references"
BIBFILE="${ROOTDIR}/main.bib"
OS="$(uname -s)"


[ -d "$ROOTDIR" ] || exit 3
[ -f "$BIBFILE" ] || exit 4


KEYS="$(sed -n '/^@/p' "$BIBFILE" | sed 's/\(^@[^{]\+{\|,$\)//g')"


if [ "$OS" = 'Linux' ]
then
  KEY=$(echo "$KEYS" | dmenu -i)
  echo -n "$KEY" | xclip -selection clipboard
elif [ "$OS" = 'Darwin' ]
then
  KEY=$(echo "$KEYS" | fzf)
  echo -n "$KEY" | pbcopy
fi


exit 0
